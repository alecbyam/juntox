# JuntoX Backend — Variables d'environnement
# Copier vers .env et remplir les valeurs

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic Claude (IA)
# Obtenir sur console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Auth JWT — génère avec: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-a-32-byte-hex-secret-do-not-use-defaults>
JWT_ALGORITHM=HS256

# Admin initial — NE PAS utiliser ces valeurs en production
# Créer l'admin via la route /api/auth/register + promotion SQL
ADMIN_EMAIL=<admin-email>
ADMIN_PASSWORD=<strong-unique-password>

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Environnement (active /docs en dev uniquement)
# ENVIRONMENT=development
