# JuntoX Backend — Variables d'environnement
# Copier vers .env et remplir les valeurs

# PostgreSQL (Railway fournit DATABASE_URL automatiquement)
DATABASE_URL=postgresql://juntox:change_me@localhost:5432/juntox

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Auth JWT
JWT_SECRET_KEY=replace_with_a_secure_random_string
JWT_ALGORITHM=HS256

# Admin initial
ADMIN_EMAIL=admin@juntox.africa
ADMIN_PASSWORD=ChangeMe123!

# CORS (domaines autorisés, séparés par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,https://juntox.africa

# Port (Railway injecte $PORT automatiquement)
PORT=8000
